# Ollama Cloud (GLM 5.2) — https://ollama.com/settings/keys
OLLAMA_API_KEY=

# Tavily web search — https://app.tavily.com
TAVILY_API_KEY=

# Slack incoming webhook the briefing is posted to
SLACK_WEBHOOK_URL=

# Vercel Blob (topic-trend history + run-context capture) — auto-injected in prod
# once a Blob store is connected to the project; `vercel env pull` for local dev
BLOB_READ_WRITE_TOKEN=

# GitHub archive: fine-grained PAT with Contents:read/write on the target repo
GITHUB_TOKEN=
GITHUB_REPO=owner/repo
# Optional, defaults to "main"
GITHUB_BRANCH=main

# Shared secret for manually triggering the deployed agent over HTTP Basic
ROUTE_AUTH_BASIC_USER=test
ROUTE_AUTH_BASIC_PASSWORD=

# VERCEL_OIDC_TOKEN is provided automatically by Vercel — no need to set locally
